<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"

       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"

       xsi:schemaLocation="
        http://www.springframework.org/schema/beans
        http://www.springframework.org/schema/beans/spring-beans.xsd">
    <bean id="Lib1" class="dependencyinjection.Library1">
        <property name="id" value="101"></property>
        <property name="name" value="Friends"></property>
        <property name="books">
            <list>
                <ref bean="B1"/>
                <ref bean="B2"/>
                <ref bean="B3"/>
            </list>
        </property>
    </bean>
    <bean id="B1" class="dependencyinjection.Book">
        <property name="bookid" value="1"></property>
        <property name="bookName" value="A Feast For Crows"></property>
    </bean>
    <bean id="B2" class="dependencyinjection.Book">
        <property name="bookid" value="02"></property>
        <property name="bookName" value="A Dance Of Dragons"></property>
    </bean>
    <bean id="B3" class="dependencyinjection.Book">
        <property name="bookid" value="03"></property>
        <property name="bookName" value="Fire And Blood"></property>
    </bean>
</beans>